{
  "name": "prometheus-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:sw",
    "build:sw": "node scripts/build-sw.mjs",
    "build:capacitor": "bash scripts/bootstrap-capacitor.sh",
    "cap:sync": "npx cap sync",
