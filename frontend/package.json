    "cap:android": "npx cap open android",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier -w src",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
